<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <sys:String x:Key="LOC_ApolloSync_Settings_AutoExportInstalledGames">インストール済みゲームをapps.jsonに自動エクスポート</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_AutoRemoveUninstalledGames">アンインストールしたゲームをapps.jsonから自動削除</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_Enable">有効</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_SyncAllOnLibraryUpdate">ライブラリ更新時に、すべてのインストール済みゲームをエクスポート</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_AppsJsonPath">Apollo/Sunshineのapps.jsonパス</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Browse">参照</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Browse_Title">apps.jsonを選択</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_AppsJsonPath_Help">ApolloまたはSunshineのapps.jsonファイルのパスを設定します。この拡張機能が管理するエントリのみが追加/削除されます。</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_AppsJsonPath_Invalid">apps.jsonのパスが無効またはアクセスできません。</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Menu_Export">Apollo/Sunshineにエクスポート</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Menu_Remove">Apollo/Sunshineから削除</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Menu_Pin">ゲームをピン留め (自動削除を防止)</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Menu_Unpin">ゲームのピン留めを解除 (自動削除を許可)</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Menu_SyncAll">すべてのインストール済みゲームをApollo/Sunshineに同期</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Menu_ManageGames">エクスポート済みゲームの管理...</sys:String>
    <sys:String x:Key="LOC_ApolloSync_MenuSection">ApolloSync</sys:String>

    <!-- Tabs -->
    <sys:String x:Key="LOC_ApolloSync_Settings_Tab_General">全般</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_Tab_Filters">フィルター</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_Tab_ManageGames">ゲーム管理</sys:String>

    <!-- General Settings -->
    <sys:String x:Key="LOC_ApolloSync_Settings_SyncOnSettingsUpdated">設定変更時に同期</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_SyncOnLibraryUpdate">ライブラリ更新時に同期</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_SyncOnStartup">Playnite起動時に同期</sys:String>

    <!-- Notification Settings -->
    <sys:String x:Key="LOC_ApolloSync_Settings_NotificationMode">通知モード</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_NotificationMode_Always">常に通知を表示</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_NotificationMode_OnUpdateOnly">同期/更新操作時のみ</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_NotificationMode_Never">通知しない (サイレント実行)</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_NotificationMode_Help">ApolloSyncが通知を表示するタイミングを制御します:
• 常に: すべての通知を表示 (エクスポート、ピン留め、エラー)
• 更新時のみ: 同期/更新操作中のみ通知を表示
• 通知しない: 完全にサイレントで実行</sys:String>

    <!-- Filter Settings -->
    <sys:String x:Key="LOC_ApolloSync_Settings_InstallationStatus">インストール状態フィルター</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_IncludeInstalledGames">インストール済みゲームを含める</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_IncludeInstalledGames_Help">有効にすると、インストール済みのゲームのみがエクスポート対象になります。</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_IncludedPlatforms">プラットフォームフィルター</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_IncludedPlatforms_Help">エクスポートに含めるプラットフォームを選択します。未選択の場合、すべてのプラットフォームが含まれます。</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_RequiredLabel">ラベルフィルター</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_RequiredLabel_Help">このラベルが付いたゲームのみをエクスポートします。未選択の場合、すべてのゲームがエクスポートされます。</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_NoLabel">ラベル指定なし</sys:String>
    <sys:String x:Key="LOC_ApolloSync_DefaultLabel_Name">Apollo/Sunshine</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_CreateDefaultLabel">既定のラベルを作成</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_CompletionStatusFilter">クリア状況フィルター</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_CompletionStatusFilter_Help">エクスポートに含めるクリア状況を選択します。未選択の場合、すべてのクリア状況が含まれます。</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_CategoryFilter">カテゴリフィルター</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_CategoryFilter_Help">エクスポートに含めるカテゴリを選択します。未選択の場合、すべてのカテゴリが含まれます。</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_FilterPreset">フィルタープリセット</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_UseFilterPreset">Playniteのフィルタープリセットを使用</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_FilterPreset_Help">有効にすると、以下の個別フィルターの代わりに選択したフィルタープリセットが使用されます。フィルタープリセットはPlayniteのメインライブラリ画面で作成できます。</sys:String>

    <!-- Manage Games Tab -->
    <sys:String x:Key="LOC_ApolloSync_Settings_ManageGames">エクスポート済みゲームの管理</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_ManageGames_Help">Apollo/Sunshineにエクスポートされたゲームを表示・管理します。ピン留めされたゲームは、フィルター変更やアンインストール時に自動削除されません。</sys:String>

    <!-- Progress and feedback messages -->
    <sys:String x:Key="LOC_ApolloSync_Progress_SyncAll_Title">Apollo/Sunshineにゲームを同期中</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Progress_SyncAll_Current">処理中: {0}</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Message_NoInstalledGames">同期するインストール済みゲームが見つかりません。</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Message_SyncAll_Complete">同期が完了しました。

成功: {0}
失敗: {1}</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Message_Export_Complete">エクスポートが完了しました。

成功: {0}
失敗: {1}</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Message_Remove_Complete">削除が完了しました。

成功: {0}
失敗: {1}</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Message_Errors">エラーが発生しました</sys:String>
    <!-- New: Permission prompt for apps.json write -->
    <sys:String x:Key="LOC_ApolloSync_Permissions_Prompt_Title">ApolloSync</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Permissions_Prompt_Body">ApolloSyncはProgram Files内のapps.jsonに書き込む権限が必要です。権限を修正しますか？</sys:String>
</ResourceDictionary>
