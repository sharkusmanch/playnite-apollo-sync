    <sys:String x:Key="LOC_ApolloSync_Settings_AppsJsonPath_Invalid">Sökvägen till apps.json är ogiltig eller inte tillgänglig.</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Menu_Export">Exportera till Apollo/Sunshine</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Menu_Remove">Ta bort från Apollo/Sunshine</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Menu_Pin">Fäst spel (förhindra automatisk borttagning)</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Menu_Unpin">Lossa spel (tillåt automatisk borttagning)</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Menu_SyncAll">Synkronisera alla installerade spel till Apollo/Sunshine</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Menu_ManageGames">Hantera exporterade spel...</sys:String>
    <sys:String x:Key="LOC_ApolloSync_MenuSection">ApolloSync</sys:String>

    <!-- Tabs -->
    <sys:String x:Key="LOC_ApolloSync_Settings_Tab_General">Allmänt</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_Tab_Filters">Filter</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_Tab_ManageGames">Hantera spel</sys:String>

    <!-- General Settings -->
    <sys:String x:Key="LOC_ApolloSync_Settings_SyncOnSettingsUpdated">Synkronisera vid ändring av inställningar</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_SyncOnLibraryUpdate">Synkronisera vid biblioteksuppdatering</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_SyncOnStartup">Synkronisera när Playnite startar</sys:String>

    <!-- Notification Settings -->
    <sys:String x:Key="LOC_ApolloSync_Settings_NotificationMode">Aviseringsläge</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_NotificationMode_Always">Visa alltid aviseringar</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_NotificationMode_OnUpdateOnly">Endast vid synkroniserings-/uppdateringsåtgärder</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_NotificationMode_Never">Aldrig (kör tyst)</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_NotificationMode_Help">Styr när ApolloSync visar aviseringar:
• Alltid: Visa alla aviseringar (exporter, fästningar, fel)
• Endast vid uppdatering: Visa aviseringar bara under synkroniserings-/uppdateringsåtgärder
• Aldrig: Kör helt tyst</sys:String>

    <!-- Filter Settings -->
    <sys:String x:Key="LOC_ApolloSync_Settings_InstallationStatus">Installationsstatusfilter</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_IncludeInstalledGames">Inkludera installerade spel</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_IncludeInstalledGames_Help">När aktiverat kommer bara installerade spel att övervägas för export.</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_IncludedPlatforms">Plattformsfilter</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_IncludedPlatforms_Help">Välj plattformar att inkludera i exporten. Om inga är valda inkluderas alla plattformar.</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_RequiredLabel">Etikettfilter</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_RequiredLabel_Help">Exportera bara spel med denna etikett. Lämna tomt för att exportera alla spel.</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_NoLabel">Ingen etikett krävs</sys:String>
    <sys:String x:Key="LOC_ApolloSync_DefaultLabel_Name">Apollo/Sunshine</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_CreateDefaultLabel">Skapa standardetikett</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_CompletionStatusFilter">Slutförandestatusfilter</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_CompletionStatusFilter_Help">Välj slutförandestatusar att inkludera i exporten. Om inga är valda inkluderas alla slutförandestatusar.</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_CategoryFilter">Kategorifilter</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_CategoryFilter_Help">Välj kategorier att inkludera i exporten. Om inga är valda inkluderas alla kategorier.</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_FilterPreset">Filterförinställning</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_UseFilterPreset">Använd Playnite-filterförinställning</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_FilterPreset_Help">När aktiverat används den valda filterförinställningen istället för de enskilda filtren nedan. Skapa filterförinställningar i Playnites huvudbiblioteksvy.</sys:String>

    <!-- Manage Games Tab -->
    <sys:String x:Key="LOC_ApolloSync_Settings_ManageGames">Hantera exporterade spel</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_ManageGames_Help">Visa och hantera spel som har exporterats till Apollo/Sunshine. Fästa spel tas inte bort automatiskt när filter ändras eller spel avinstalleras.</sys:String>

    <!-- Progress and feedback messages -->
    <sys:String x:Key="LOC_ApolloSync_Progress_SyncAll_Title">Synkroniserar spel till Apollo/Sunshine</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Progress_SyncAll_Current">Bearbetar: {0}</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Message_NoInstalledGames">Inga installerade spel hittades att synkronisera.</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Message_SyncAll_Complete">Synkronisering slutförd.

Lyckades: {0}
Misslyckades: {1}</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Message_Export_Complete">Export slutförd.

Lyckades: {0}
Misslyckades: {1}</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Message_Remove_Complete">Borttagning slutförd.

Lyckades: {0}
Misslyckades: {1}</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Message_Errors">Fel uppstod</sys:String>
    <!-- New: Permission prompt for apps.json write -->
    <sys:String x:Key="LOC_ApolloSync_Permissions_Prompt_Title">ApolloSync</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Permissions_Prompt_Body">ApolloSync behöver behörighet att skriva apps.json i Program Files. Tillåt rättning av behörigheter?</sys:String>
</ResourceDictionary>
