<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <sys:String x:Key="LOC_ApolloSync_Settings_AutoExportInstalledGames">Installierte Spiele automatisch in apps.json exportieren</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_AutoRemoveUninstalledGames">Deinstallierte Spiele automatisch aus apps.json entfernen</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_Enable">Aktivieren</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_SyncAllOnLibraryUpdate">Bei Bibliotheksaktualisierung sicherstellen, dass alle installierten Spiele exportiert sind</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_AppsJsonPath">Pfad zur Apollo/Sunshine apps.json</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Browse">Durchsuchen</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Browse_Title">apps.json auswählen</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_AppsJsonPath_Help">Legen Sie den Pfad zur Apollo- oder Sunshine-Datei apps.json fest. Nur von dieser Erweiterung verwaltete Einträge werden hinzugefügt/entfernt.</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_AppsJsonPath_Invalid">Der Pfad zur apps.json ist ungültig oder nicht zugänglich.</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Menu_Export">Zu Apollo/Sunshine exportieren</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Menu_Remove">Aus Apollo/Sunshine entfernen</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Menu_Pin">Spiel anheften (automatisches Entfernen verhindern)</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Menu_Unpin">Spiel loslösen (automatisches Entfernen erlauben)</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Menu_SyncAll">Alle installierten Spiele mit Apollo/Sunshine synchronisieren</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Menu_ManageGames">Exportierte Spiele verwalten...</sys:String>
    <sys:String x:Key="LOC_ApolloSync_MenuSection">ApolloSync</sys:String>

    <!-- Tabs -->
    <sys:String x:Key="LOC_ApolloSync_Settings_Tab_General">Allgemein</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_Tab_Filters">Filter</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_Tab_ManageGames">Spiele verwalten</sys:String>

    <!-- General Settings -->
    <sys:String x:Key="LOC_ApolloSync_Settings_SyncOnSettingsUpdated">Synchronisieren bei Einstellungsänderungen</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_SyncOnLibraryUpdate">Synchronisieren bei Bibliotheksaktualisierung</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_SyncOnStartup">Synchronisieren beim Start von Playnite</sys:String>

    <!-- Notification Settings -->
    <sys:String x:Key="LOC_ApolloSync_Settings_NotificationMode">Benachrichtigungsmodus</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_NotificationMode_Always">Benachrichtigungen immer anzeigen</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_NotificationMode_OnUpdateOnly">Nur bei Synchronisierungs-/Aktualisierungsvorgängen</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_NotificationMode_Never">Nie (im Hintergrund ausführen)</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_NotificationMode_Help">Steuert, wann ApolloSync Benachrichtigungen anzeigt:
• Immer: Alle Benachrichtigungen anzeigen (Exporte, Anheftungen, Fehler)
• Nur bei Aktualisierung: Nur während Synchronisierungs-/Aktualisierungsvorgängen
• Nie: Vollständig im Hintergrund ausführen</sys:String>

    <!-- Filter Settings -->
    <sys:String x:Key="LOC_ApolloSync_Settings_InstallationStatus">Installationsstatusfilter</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_IncludeInstalledGames">Installierte Spiele einschließen</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_IncludeInstalledGames_Help">Wenn aktiviert, werden nur installierte Spiele für den Export berücksichtigt.</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_IncludedPlatforms">Plattformfilter</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_IncludedPlatforms_Help">Wählen Sie Plattformen für den Export aus. Wenn keine ausgewählt sind, werden alle Plattformen einbezogen.</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_RequiredLabel">Label-Filter</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_RequiredLabel_Help">Nur Spiele mit diesem Label exportieren. Leer lassen, um alle Spiele zu exportieren.</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_NoLabel">Kein Label erforderlich</sys:String>
    <sys:String x:Key="LOC_ApolloSync_DefaultLabel_Name">Apollo/Sunshine</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_CreateDefaultLabel">Standard-Label erstellen</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_CompletionStatusFilter">Abschlussstatusfilter</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_CompletionStatusFilter_Help">Wählen Sie Abschlussstatus für den Export aus. Wenn keine ausgewählt sind, werden alle Abschlussstatus einbezogen.</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_CategoryFilter">Kategoriefilter</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_CategoryFilter_Help">Wählen Sie Kategorien für den Export aus. Wenn keine ausgewählt sind, werden alle Kategorien einbezogen.</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_FilterPreset">Filtervoreinstellung</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_UseFilterPreset">Playnite-Filtervoreinstellung verwenden</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_FilterPreset_Help">Wenn aktiviert, wird die ausgewählte Filtervoreinstellung anstelle der einzelnen Filter unten verwendet. Erstellen Sie Filtervoreinstellungen in der Hauptbibliotheksansicht von Playnite.</sys:String>

    <!-- Manage Games Tab -->
    <sys:String x:Key="LOC_ApolloSync_Settings_ManageGames">Exportierte Spiele verwalten</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_ManageGames_Help">Anzeigen und Verwalten von Spielen, die zu Apollo/Sunshine exportiert wurden. Angeheftete Spiele werden nicht automatisch entfernt, wenn sich Filter ändern oder Spiele deinstalliert werden.</sys:String>

    <!-- Progress and feedback messages -->
    <sys:String x:Key="LOC_ApolloSync_Progress_SyncAll_Title">Spiele mit Apollo/Sunshine synchronisieren</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Progress_SyncAll_Current">Verarbeitung: {0}</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Message_NoInstalledGames">Keine installierten Spiele zum Synchronisieren gefunden.</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Message_SyncAll_Complete">Synchronisierung erfolgreich abgeschlossen.

Erfolgreich: {0}
Fehlgeschlagen: {1}</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Message_Export_Complete">Export abgeschlossen.

Erfolgreich: {0}
Fehlgeschlagen: {1}</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Message_Remove_Complete">Entfernung abgeschlossen.

Erfolgreich: {0}
Fehlgeschlagen: {1}</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Message_Errors">Fehler aufgetreten</sys:String>
    <!-- New: Permission prompt for apps.json write -->
    <sys:String x:Key="LOC_ApolloSync_Permissions_Prompt_Title">ApolloSync</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Permissions_Prompt_Body">ApolloSync benötigt die Berechtigung, apps.json in Programme zu schreiben. Berechtigungen korrigieren?</sys:String>
</ResourceDictionary>
