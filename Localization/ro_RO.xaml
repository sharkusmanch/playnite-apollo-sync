<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <sys:String x:Key="LOC_ApolloSync_Settings_AutoExportInstalledGames">Exportă automat jocurile instalate în apps.json</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_AutoRemoveUninstalledGames">Elimină automat jocurile dezinstalate din apps.json</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_Enable">Activare</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_SyncAllOnLibraryUpdate">La actualizarea bibliotecii, asigură-te că toate jocurile instalate sunt exportate</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_AppsJsonPath">Calea către fișierul apps.json al Apollo/Sunshine</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Browse">Răsfoiește</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Browse_Title">Selectează apps.json</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_AppsJsonPath_Help">Setează calea către fișierul apps.json al Apollo sau Sunshine. Doar intrările gestionate de această extensie vor fi adăugate sau eliminate.</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_AppsJsonPath_Invalid">Calea către apps.json este invalidă sau inaccesibilă.</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Menu_Export">Exportă în Apollo/Sunshine</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Menu_Remove">Elimină din Apollo/Sunshine</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Menu_Pin">Fixează jocul (previne eliminarea automată)</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Menu_Unpin">Defixează jocul (permite eliminarea automată)</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Menu_SyncAll">Sincronizează toate jocurile instalate cu Apollo/Sunshine</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Menu_ManageGames">Gestionează jocurile exportate...</sys:String>
    <sys:String x:Key="LOC_ApolloSync_MenuSection">ApolloSync</sys:String>

    <!-- Tabs -->
    <sys:String x:Key="LOC_ApolloSync_Settings_Tab_General">General</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_Tab_Filters">Filtre</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_Tab_ManageGames">Gestionează jocuri</sys:String>

    <!-- General Settings -->
    <sys:String x:Key="LOC_ApolloSync_Settings_SyncOnSettingsUpdated">Sincronizează la actualizarea setărilor</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_SyncOnLibraryUpdate">Sincronizează la actualizarea bibliotecii</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_SyncOnStartup">Sincronizează la pornirea Playnite</sys:String>

    <!-- Notification Settings -->
    <sys:String x:Key="LOC_ApolloSync_Settings_NotificationMode">Mod notificări</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_NotificationMode_Always">Afișează întotdeauna notificările</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_NotificationMode_OnUpdateOnly">Doar la operațiuni de sincronizare/actualizare</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_NotificationMode_Never">Niciodată (rulează silențios)</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_NotificationMode_Help">Controlează când ApolloSync afișează notificări:
• Întotdeauna: Afișează toate notificările (exportări, fixări, erori)
• Doar la actualizare: Afișează notificările doar în timpul operațiunilor de sincronizare/actualizare
• Niciodată: Rulează complet silențios</sys:String>

    <!-- Filter Settings -->
    <sys:String x:Key="LOC_ApolloSync_Settings_InstallationStatus">Filtru stare instalare</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_IncludeInstalledGames">Include jocurile instalate</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_IncludeInstalledGames_Help">Când este activat, doar jocurile instalate vor fi luate în considerare pentru export.</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_IncludedPlatforms">Filtre platformă</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_IncludedPlatforms_Help">Selectează platformele de inclus în export. Dacă nu este selectată niciuna, toate platformele vor fi incluse.</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_RequiredLabel">Filtru etichetă</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_RequiredLabel_Help">Exportă doar jocurile care au această etichetă. Lasă neselectat pentru a exporta toate jocurile.</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_NoLabel">Nicio etichetă necesară</sys:String>
    <sys:String x:Key="LOC_ApolloSync_DefaultLabel_Name">Apollo/Sunshine</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_CreateDefaultLabel">Creează etichetă implicită</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_CompletionStatusFilter">Filtru stare finalizare</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_CompletionStatusFilter_Help">Selectează stările de finalizare de inclus în export. Dacă nu este selectată niciuna, toate stările vor fi incluse.</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_CategoryFilter">Filtru categorie</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_CategoryFilter_Help">Selectează categoriile de inclus în export. Dacă nu este selectată niciuna, toate categoriile vor fi incluse.</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_FilterPreset">Presetare filtru</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_UseFilterPreset">Folosește presetarea de filtru Playnite</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_FilterPreset_Help">Când este activat, presetarea de filtru selectată va fi folosită în locul filtrelor individuale de mai jos. Creează presetări de filtru în vizualizarea principală a bibliotecii Playnite.</sys:String>

    <!-- Manage Games Tab -->
    <sys:String x:Key="LOC_ApolloSync_Settings_ManageGames">Gestionează jocurile exportate</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_ManageGames_Help">Vizualizează și gestionează jocurile care au fost exportate în Apollo/Sunshine. Jocurile fixate nu vor fi eliminate automat când filtrele se schimbă sau jocurile sunt dezinstalate.</sys:String>

    <!-- Progress and feedback messages -->
    <sys:String x:Key="LOC_ApolloSync_Progress_SyncAll_Title">Sincronizare jocuri cu Apollo/Sunshine</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Progress_SyncAll_Current">Se procesează: {0}</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Message_NoInstalledGames">Nu s-au găsit jocuri instalate pentru sincronizare.</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Message_SyncAll_Complete">Sincronizare finalizată cu succes.

Reușite: {0}
Eșuate: {1}</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Message_Export_Complete">Export finalizat.

Reușite: {0}
Eșuate: {1}</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Message_Remove_Complete">Eliminare finalizată.

Reușite: {0}
Eșuate: {1}</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Message_Errors">Au fost întâmpinate erori</sys:String>
    <!-- New: Permission prompt for apps.json write -->
    <sys:String x:Key="LOC_ApolloSync_Permissions_Prompt_Title">ApolloSync</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Permissions_Prompt_Body">ApolloSync are nevoie de permisiunea de a scrie apps.json în Program Files. Permiți corectarea permisiunilor?</sys:String>
</ResourceDictionary>
