<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <sys:String x:Key="LOC_ApolloSync_Settings_AutoExportInstalledGames">Automatycznie eksportuj zainstalowane gry do apps.json</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_AutoRemoveUninstalledGames">Automatycznie usuwaj odinstalowane gry z apps.json</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_Enable">Włącz</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_SyncAllOnLibraryUpdate">Przy aktualizacji biblioteki upewnij się, że wszystkie zainstalowane gry są wyeksportowane</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_AppsJsonPath">Ścieżka do pliku Apollo/Sunshine apps.json</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Browse">Przeglądaj</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Browse_Title">Wybierz apps.json</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_AppsJsonPath_Help">Ustaw ścieżkę do pliku apps.json Apollo lub Sunshine. Tylko wpisy zarządzane przez to rozszerzenie będą dodawane/usuwane.</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_AppsJsonPath_Invalid">Ścieżka do apps.json jest nieprawidłowa lub niedostępna.</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Menu_Export">Eksportuj do Apollo/Sunshine</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Menu_Remove">Usuń z Apollo/Sunshine</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Menu_Pin">Przypnij grę (zapobiegaj automatycznemu usuwaniu)</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Menu_Unpin">Odepnij grę (zezwól na automatyczne usuwanie)</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Menu_SyncAll">Synchronizuj wszystkie zainstalowane gry z Apollo/Sunshine</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Menu_ManageGames">Zarządzaj wyeksportowanymi grami...</sys:String>
    <sys:String x:Key="LOC_ApolloSync_MenuSection">ApolloSync</sys:String>

    <!-- Tabs -->
    <sys:String x:Key="LOC_ApolloSync_Settings_Tab_General">Ogólne</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_Tab_Filters">Filtry</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_Tab_ManageGames">Zarządzaj grami</sys:String>

    <!-- General Settings -->
    <sys:String x:Key="LOC_ApolloSync_Settings_SyncOnSettingsUpdated">Synchronizuj przy zmianie ustawień</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_SyncOnLibraryUpdate">Synchronizuj przy aktualizacji biblioteki</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_SyncOnStartup">Synchronizuj przy uruchomieniu Playnite</sys:String>

    <!-- Notification Settings -->
    <sys:String x:Key="LOC_ApolloSync_Settings_NotificationMode">Tryb powiadomień</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_NotificationMode_Always">Zawsze pokazuj powiadomienia</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_NotificationMode_OnUpdateOnly">Tylko przy synchronizacji/aktualizacji</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_NotificationMode_Never">Nigdy (działaj w tle)</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_NotificationMode_Help">Określa, kiedy ApolloSync wyświetla powiadomienia:
• Zawsze: Pokaż wszystkie powiadomienia (eksporty, przypięcia, błędy)
• Tylko przy aktualizacji: Pokaż powiadomienia tylko podczas synchronizacji/aktualizacji
• Nigdy: Działaj całkowicie w tle</sys:String>

    <!-- Filter Settings -->
    <sys:String x:Key="LOC_ApolloSync_Settings_InstallationStatus">Filtr statusu instalacji</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_IncludeInstalledGames">Uwzględnij zainstalowane gry</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_IncludeInstalledGames_Help">Po włączeniu tylko zainstalowane gry będą brane pod uwagę przy eksporcie.</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_IncludedPlatforms">Filtry platform</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_IncludedPlatforms_Help">Wybierz platformy do uwzględnienia w eksporcie. Jeśli żadna nie jest wybrana, uwzględnione zostaną wszystkie platformy.</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_RequiredLabel">Filtr etykiet</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_RequiredLabel_Help">Eksportuj tylko gry z tą etykietą. Pozostaw puste, aby eksportować wszystkie gry.</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_NoLabel">Etykieta nie jest wymagana</sys:String>
    <sys:String x:Key="LOC_ApolloSync_DefaultLabel_Name">Apollo/Sunshine</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_CreateDefaultLabel">Utwórz domyślną etykietę</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_CompletionStatusFilter">Filtr statusu ukończenia</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_CompletionStatusFilter_Help">Wybierz statusy ukończenia do uwzględnienia w eksporcie. Jeśli żaden nie jest wybrany, uwzględnione zostaną wszystkie statusy ukończenia.</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_CategoryFilter">Filtr kategorii</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_CategoryFilter_Help">Wybierz kategorie do uwzględnienia w eksporcie. Jeśli żadna nie jest wybrana, uwzględnione zostaną wszystkie kategorie.</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_FilterPreset">Szablon filtrów</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_UseFilterPreset">Użyj szablonu filtrów Playnite</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_FilterPreset_Help">Po włączeniu wybrany szablon filtrów zostanie użyty zamiast poszczególnych filtrów poniżej. Twórz szablony filtrów w głównym widoku biblioteki Playnite.</sys:String>

    <!-- Manage Games Tab -->
    <sys:String x:Key="LOC_ApolloSync_Settings_ManageGames">Zarządzaj wyeksportowanymi grami</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_ManageGames_Help">Przeglądaj i zarządzaj grami wyeksportowanymi do Apollo/Sunshine. Przypięte gry nie będą automatycznie usuwane przy zmianie filtrów lub odinstalowaniu gier.</sys:String>

    <!-- Progress and feedback messages -->
    <sys:String x:Key="LOC_ApolloSync_Progress_SyncAll_Title">Synchronizacja gier z Apollo/Sunshine</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Progress_SyncAll_Current">Przetwarzanie: {0}</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Message_NoInstalledGames">Nie znaleziono zainstalowanych gier do synchronizacji.</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Message_SyncAll_Complete">Synchronizacja zakończona pomyślnie.

Powodzenie: {0}
Niepowodzenie: {1}</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Message_Export_Complete">Eksport zakończony.

Powodzenie: {0}
Niepowodzenie: {1}</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Message_Remove_Complete">Usuwanie zakończone.

Powodzenie: {0}
Niepowodzenie: {1}</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Message_Errors">Wystąpiły błędy</sys:String>
    <!-- New: Permission prompt for apps.json write -->
    <sys:String x:Key="LOC_ApolloSync_Permissions_Prompt_Title">ApolloSync</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Permissions_Prompt_Body">ApolloSync potrzebuje uprawnień do zapisu apps.json w Program Files. Czy naprawić uprawnienia?</sys:String>
</ResourceDictionary>
