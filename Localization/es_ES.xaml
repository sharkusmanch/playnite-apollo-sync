<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <sys:String x:Key="LOC_ApolloSync_Settings_AutoExportInstalledGames">Exportar automáticamente los juegos instalados a apps.json</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_AutoRemoveUninstalledGames">Eliminar automáticamente los juegos desinstalados de apps.json</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_Enable">Activar</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_SyncAllOnLibraryUpdate">Al actualizar la biblioteca, asegurar que todos los juegos instalados estén exportados</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_AppsJsonPath">Ruta al archivo apps.json de Apollo/Sunshine</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Browse">Examinar</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Browse_Title">Seleccionar apps.json</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_AppsJsonPath_Help">Establece la ruta al archivo apps.json de Apollo o Sunshine. Solo se añadirán o eliminarán las entradas gestionadas por esta extensión.</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_AppsJsonPath_Invalid">La ruta de apps.json no es válida o no es accesible.</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Menu_Export">Exportar a Apollo/Sunshine</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Menu_Remove">Eliminar de Apollo/Sunshine</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Menu_Pin">Fijar juego (evitar eliminación automática)</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Menu_Unpin">Desfijar juego (permitir eliminación automática)</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Menu_SyncAll">Sincronizar todos los juegos instalados con Apollo/Sunshine</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Menu_ManageGames">Administrar juegos exportados...</sys:String>
    <sys:String x:Key="LOC_ApolloSync_MenuSection">ApolloSync</sys:String>

    <!-- Tabs -->
    <sys:String x:Key="LOC_ApolloSync_Settings_Tab_General">General</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_Tab_Filters">Filtros</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_Tab_ManageGames">Administrar juegos</sys:String>

    <!-- General Settings -->
    <sys:String x:Key="LOC_ApolloSync_Settings_SyncOnSettingsUpdated">Sincronizar al actualizar la configuración</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_SyncOnLibraryUpdate">Sincronizar al actualizar la biblioteca</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_SyncOnStartup">Sincronizar al iniciar Playnite</sys:String>

    <!-- Notification Settings -->
    <sys:String x:Key="LOC_ApolloSync_Settings_NotificationMode">Modo de notificaciones</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_NotificationMode_Always">Mostrar siempre las notificaciones</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_NotificationMode_OnUpdateOnly">Solo durante operaciones de sincronización/actualización</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_NotificationMode_Never">Nunca (ejecutar silenciosamente)</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_NotificationMode_Help">Controla cuándo ApolloSync muestra notificaciones:
• Siempre: Mostrar todas las notificaciones (exportaciones, fijados, errores)
• Solo al actualizar: Solo mostrar notificaciones durante operaciones de sincronización/actualización
• Nunca: Ejecutar completamente en silencio</sys:String>

    <!-- Filter Settings -->
    <sys:String x:Key="LOC_ApolloSync_Settings_InstallationStatus">Filtro de estado de instalación</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_IncludeInstalledGames">Incluir juegos instalados</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_IncludeInstalledGames_Help">Cuando está activado, solo se considerarán para exportar los juegos instalados.</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_IncludedPlatforms">Filtros de plataforma</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_IncludedPlatforms_Help">Selecciona las plataformas a incluir en la exportación. Si no se selecciona ninguna, se incluirán todas las plataformas.</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_RequiredLabel">Filtro de etiqueta</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_RequiredLabel_Help">Solo exportar juegos que tengan esta etiqueta. Déjalo sin seleccionar para exportar todos los juegos.</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_NoLabel">Sin etiqueta requerida</sys:String>
    <sys:String x:Key="LOC_ApolloSync_DefaultLabel_Name">Apollo/Sunshine</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_CreateDefaultLabel">Crear etiqueta predeterminada</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_CompletionStatusFilter">Filtro de estado de finalización</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_CompletionStatusFilter_Help">Selecciona los estados de finalización a incluir en la exportación. Si no se selecciona ninguno, se incluirán todos los estados.</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_CategoryFilter">Filtro de categoría</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_CategoryFilter_Help">Selecciona las categorías a incluir en la exportación. Si no se selecciona ninguna, se incluirán todas las categorías.</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_FilterPreset">Preajuste de filtro</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_UseFilterPreset">Usar preajuste de filtro de Playnite</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_FilterPreset_Help">Cuando está activado, se usará el preajuste de filtro seleccionado en lugar de los filtros individuales de abajo. Crea preajustes de filtro en la vista principal de la biblioteca de Playnite.</sys:String>

    <!-- Manage Games Tab -->
    <sys:String x:Key="LOC_ApolloSync_Settings_ManageGames">Administrar juegos exportados</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_ManageGames_Help">Ver y administrar los juegos que han sido exportados a Apollo/Sunshine. Los juegos fijados no se eliminarán automáticamente cuando cambien los filtros o se desinstalen los juegos.</sys:String>

    <!-- Progress and feedback messages -->
    <sys:String x:Key="LOC_ApolloSync_Progress_SyncAll_Title">Sincronizando juegos con Apollo/Sunshine</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Progress_SyncAll_Current">Procesando: {0}</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Message_NoInstalledGames">No se encontraron juegos instalados para sincronizar.</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Message_SyncAll_Complete">Sincronización completada correctamente.

Correctos: {0}
Fallidos: {1}</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Message_Export_Complete">Exportación completada.

Correctos: {0}
Fallidos: {1}</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Message_Remove_Complete">Eliminación completada.

Correctos: {0}
Fallidos: {1}</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Message_Errors">Se encontraron errores</sys:String>
    <!-- New: Permission prompt for apps.json write -->
    <sys:String x:Key="LOC_ApolloSync_Permissions_Prompt_Title">ApolloSync</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Permissions_Prompt_Body">ApolloSync necesita permiso para escribir apps.json en Program Files. ¿Permitir corregir los permisos?</sys:String>
</ResourceDictionary>
