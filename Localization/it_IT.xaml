<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <sys:String x:Key="LOC_ApolloSync_Settings_AutoExportInstalledGames">Esporta automaticamente i giochi installati in apps.json</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_AutoRemoveUninstalledGames">Rimuovi automaticamente i giochi disinstallati da apps.json</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_Enable">Attiva</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_SyncAllOnLibraryUpdate">All'aggiornamento della libreria, assicurarsi che tutti i giochi installati siano esportati</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_AppsJsonPath">Percorso del file apps.json di Apollo/Sunshine</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Browse">Sfoglia</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Browse_Title">Seleziona apps.json</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_AppsJsonPath_Help">Imposta il percorso del file apps.json di Apollo o Sunshine. Verranno aggiunte o rimosse solo le voci gestite da questa estensione.</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_AppsJsonPath_Invalid">Il percorso di apps.json non è valido o non è accessibile.</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Menu_Export">Esporta in Apollo/Sunshine</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Menu_Remove">Rimuovi da Apollo/Sunshine</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Menu_Pin">Fissa il gioco (impedisci la rimozione automatica)</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Menu_Unpin">Sblocca il gioco (consenti la rimozione automatica)</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Menu_SyncAll">Sincronizza tutti i giochi installati con Apollo/Sunshine</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Menu_ManageGames">Gestisci giochi esportati...</sys:String>
    <sys:String x:Key="LOC_ApolloSync_MenuSection">ApolloSync</sys:String>

    <!-- Tabs -->
    <sys:String x:Key="LOC_ApolloSync_Settings_Tab_General">Generale</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_Tab_Filters">Filtri</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_Tab_ManageGames">Gestisci giochi</sys:String>

    <!-- General Settings -->
    <sys:String x:Key="LOC_ApolloSync_Settings_SyncOnSettingsUpdated">Sincronizza quando le impostazioni vengono aggiornate</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_SyncOnLibraryUpdate">Sincronizza quando la libreria viene aggiornata</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_SyncOnStartup">Sincronizza all'avvio di Playnite</sys:String>

    <!-- Notification Settings -->
    <sys:String x:Key="LOC_ApolloSync_Settings_NotificationMode">Modalità di notifica</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_NotificationMode_Always">Mostra sempre le notifiche</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_NotificationMode_OnUpdateOnly">Solo durante operazioni di sincronizzazione/aggiornamento</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_NotificationMode_Never">Mai (esegui silenziosamente)</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_NotificationMode_Help">Controlla quando ApolloSync mostra le notifiche:
• Sempre: Mostra tutte le notifiche (esportazioni, fissaggi, errori)
• Solo aggiornamento: Mostra le notifiche solo durante le operazioni di sincronizzazione/aggiornamento
• Mai: Esegui completamente in silenzio</sys:String>

    <!-- Filter Settings -->
    <sys:String x:Key="LOC_ApolloSync_Settings_InstallationStatus">Filtro stato di installazione</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_IncludeInstalledGames">Includi giochi installati</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_IncludeInstalledGames_Help">Quando attivato, solo i giochi installati verranno considerati per l'esportazione.</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_IncludedPlatforms">Filtri piattaforma</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_IncludedPlatforms_Help">Seleziona le piattaforme da includere nell'esportazione. Se non ne viene selezionata nessuna, verranno incluse tutte le piattaforme.</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_RequiredLabel">Filtro etichetta</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_RequiredLabel_Help">Esporta solo i giochi con questa etichetta. Lascia non selezionato per esportare tutti i giochi.</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_NoLabel">Nessuna etichetta richiesta</sys:String>
    <sys:String x:Key="LOC_ApolloSync_DefaultLabel_Name">Apollo/Sunshine</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_CreateDefaultLabel">Crea etichetta predefinita</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_CompletionStatusFilter">Filtro stato di completamento</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_CompletionStatusFilter_Help">Seleziona gli stati di completamento da includere nell'esportazione. Se non ne viene selezionato nessuno, verranno inclusi tutti gli stati.</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_CategoryFilter">Filtro categoria</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_CategoryFilter_Help">Seleziona le categorie da includere nell'esportazione. Se non ne viene selezionata nessuna, verranno incluse tutte le categorie.</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_FilterPreset">Preset filtro</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_UseFilterPreset">Usa preset filtro di Playnite</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_FilterPreset_Help">Quando attivato, verrà utilizzato il preset filtro selezionato al posto dei filtri individuali sottostanti. Crea i preset filtro nella vista principale della libreria di Playnite.</sys:String>

    <!-- Manage Games Tab -->
    <sys:String x:Key="LOC_ApolloSync_Settings_ManageGames">Gestisci giochi esportati</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_ManageGames_Help">Visualizza e gestisci i giochi che sono stati esportati in Apollo/Sunshine. I giochi fissati non verranno rimossi automaticamente quando i filtri cambiano o i giochi vengono disinstallati.</sys:String>

    <!-- Progress and feedback messages -->
    <sys:String x:Key="LOC_ApolloSync_Progress_SyncAll_Title">Sincronizzazione dei giochi con Apollo/Sunshine</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Progress_SyncAll_Current">Elaborazione: {0}</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Message_NoInstalledGames">Nessun gioco installato trovato da sincronizzare.</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Message_SyncAll_Complete">Sincronizzazione completata con successo.

Riusciti: {0}
Falliti: {1}</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Message_Export_Complete">Esportazione completata.

Riusciti: {0}
Falliti: {1}</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Message_Remove_Complete">Rimozione completata.

Riusciti: {0}
Falliti: {1}</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Message_Errors">Errori riscontrati</sys:String>
    <!-- New: Permission prompt for apps.json write -->
    <sys:String x:Key="LOC_ApolloSync_Permissions_Prompt_Title">ApolloSync</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Permissions_Prompt_Body">ApolloSync ha bisogno dell'autorizzazione per scrivere apps.json in Program Files. Consentire la correzione dei permessi?</sys:String>
</ResourceDictionary>
