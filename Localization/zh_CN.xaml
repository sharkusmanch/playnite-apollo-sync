<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <sys:String x:Key="LOC_ApolloSync_Settings_AutoExportInstalledGames">自动将已安装的游戏导出到apps.json</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_AutoRemoveUninstalledGames">自动从apps.json中移除已卸载的游戏</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_Enable">启用</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_SyncAllOnLibraryUpdate">库更新时，确保所有已安装的游戏已导出</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_AppsJsonPath">Apollo/Sunshine apps.json路径</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Browse">浏览</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Browse_Title">选择apps.json</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_AppsJsonPath_Help">设置Apollo或Sunshine apps.json文件的路径。只有由此扩展管理的条目会被添加/移除。</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_AppsJsonPath_Invalid">apps.json路径无效或无法访问。</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Menu_Export">导出到Apollo/Sunshine</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Menu_Remove">从Apollo/Sunshine移除</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Menu_Pin">固定游戏（防止自动移除）</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Menu_Unpin">取消固定游戏（允许自动移除）</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Menu_SyncAll">将所有已安装的游戏同步到Apollo/Sunshine</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Menu_ManageGames">管理已导出的游戏...</sys:String>
    <sys:String x:Key="LOC_ApolloSync_MenuSection">ApolloSync</sys:String>

    <!-- Tabs -->
    <sys:String x:Key="LOC_ApolloSync_Settings_Tab_General">常规</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_Tab_Filters">筛选</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_Tab_ManageGames">管理游戏</sys:String>

    <!-- General Settings -->
    <sys:String x:Key="LOC_ApolloSync_Settings_SyncOnSettingsUpdated">设置更新时同步</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_SyncOnLibraryUpdate">库更新时同步</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_SyncOnStartup">Playnite启动时同步</sys:String>

    <!-- Notification Settings -->
    <sys:String x:Key="LOC_ApolloSync_Settings_NotificationMode">通知模式</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_NotificationMode_Always">始终显示通知</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_NotificationMode_OnUpdateOnly">仅在同步/更新操作时</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_NotificationMode_Never">从不（静默运行）</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_NotificationMode_Help">控制ApolloSync显示通知的时机：
• 始终：显示所有通知（导出、固定、错误）
• 仅更新时：仅在同步/更新操作期间显示通知
• 从不：完全静默运行</sys:String>

    <!-- Filter Settings -->
    <sys:String x:Key="LOC_ApolloSync_Settings_InstallationStatus">安装状态筛选</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_IncludeInstalledGames">包含已安装的游戏</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_IncludeInstalledGames_Help">启用后，仅已安装的游戏会被纳入导出范围。</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_IncludedPlatforms">平台筛选</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_IncludedPlatforms_Help">选择要包含在导出中的平台。如果未选择任何平台，则包含所有平台。</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_RequiredLabel">标签筛选</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_RequiredLabel_Help">仅导出具有此标签的游戏。不选择则导出所有游戏。</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_NoLabel">不需要标签</sys:String>
    <sys:String x:Key="LOC_ApolloSync_DefaultLabel_Name">Apollo/Sunshine</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_CreateDefaultLabel">创建默认标签</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_CompletionStatusFilter">完成状态筛选</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_CompletionStatusFilter_Help">选择要包含在导出中的完成状态。如果未选择，则包含所有完成状态。</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_CategoryFilter">分类筛选</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_CategoryFilter_Help">选择要包含在导出中的分类。如果未选择，则包含所有分类。</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_FilterPreset">筛选预设</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_UseFilterPreset">使用Playnite筛选预设</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_FilterPreset_Help">启用后，将使用所选的筛选预设替代下方的各项筛选条件。可在Playnite的主库视图中创建筛选预设。</sys:String>

    <!-- Manage Games Tab -->
    <sys:String x:Key="LOC_ApolloSync_Settings_ManageGames">管理已导出的游戏</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_ManageGames_Help">查看和管理已导出到Apollo/Sunshine的游戏。固定的游戏在筛选条件变更或游戏卸载时不会被自动移除。</sys:String>

    <!-- Progress and feedback messages -->
    <sys:String x:Key="LOC_ApolloSync_Progress_SyncAll_Title">正在将游戏同步到Apollo/Sunshine</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Progress_SyncAll_Current">正在处理：{0}</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Message_NoInstalledGames">未找到可同步的已安装游戏。</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Message_SyncAll_Complete">同步完成。

成功：{0}
失败：{1}</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Message_Export_Complete">导出完成。

成功：{0}
失败：{1}</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Message_Remove_Complete">移除完成。

成功：{0}
失败：{1}</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Message_Errors">遇到错误</sys:String>
    <!-- New: Permission prompt for apps.json write -->
    <sys:String x:Key="LOC_ApolloSync_Permissions_Prompt_Title">ApolloSync</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Permissions_Prompt_Body">ApolloSync需要权限以写入Program Files中的apps.json。是否允许修复权限？</sys:String>
</ResourceDictionary>
