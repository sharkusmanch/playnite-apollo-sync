<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <sys:String x:Key="LOC_ApolloSync_Settings_AutoExportInstalledGames">Automaticky exportovat nainstalované hry do apps.json</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_AutoRemoveUninstalledGames">Automaticky odebrat odinstalované hry z apps.json</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_Enable">Povolit</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_SyncAllOnLibraryUpdate">Při aktualizaci knihovny zajistit, aby byly všechny nainstalované hry exportovány</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_AppsJsonPath">Cesta k souboru Apollo/Sunshine apps.json</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Browse">Procházet</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Browse_Title">Vybrat apps.json</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_AppsJsonPath_Help">Nastavte cestu k souboru apps.json aplikace Apollo nebo Sunshine. Budou přidány/odebrány pouze položky spravované tímto rozšířením.</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_AppsJsonPath_Invalid">Cesta k apps.json je neplatná nebo nedostupná.</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Menu_Export">Exportovat do Apollo/Sunshine</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Menu_Remove">Odebrat z Apollo/Sunshine</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Menu_Pin">Připnout hru (zabránit automatickému odebrání)</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Menu_Unpin">Odepnout hru (povolit automatické odebrání)</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Menu_SyncAll">Synchronizovat všechny nainstalované hry do Apollo/Sunshine</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Menu_ManageGames">Spravovat exportované hry...</sys:String>
    <sys:String x:Key="LOC_ApolloSync_MenuSection">ApolloSync</sys:String>

    <!-- Tabs -->
    <sys:String x:Key="LOC_ApolloSync_Settings_Tab_General">Obecné</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_Tab_Filters">Filtry</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_Tab_ManageGames">Správa her</sys:String>

    <!-- General Settings -->
    <sys:String x:Key="LOC_ApolloSync_Settings_SyncOnSettingsUpdated">Synchronizovat při změně nastavení</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_SyncOnLibraryUpdate">Synchronizovat při aktualizaci knihovny</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_SyncOnStartup">Synchronizovat při spuštění Playnite</sys:String>

    <!-- Notification Settings -->
    <sys:String x:Key="LOC_ApolloSync_Settings_NotificationMode">Režim oznámení</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_NotificationMode_Always">Vždy zobrazovat oznámení</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_NotificationMode_OnUpdateOnly">Pouze při synchronizaci/aktualizaci</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_NotificationMode_Never">Nikdy (běžet tiše)</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_NotificationMode_Help">Určuje, kdy ApolloSync zobrazuje oznámení:
• Vždy: Zobrazit všechna oznámení (exporty, připnutí, chyby)
• Pouze při aktualizaci: Zobrazit oznámení jen během synchronizace/aktualizace
• Nikdy: Běžet zcela tiše</sys:String>

    <!-- Filter Settings -->
    <sys:String x:Key="LOC_ApolloSync_Settings_InstallationStatus">Filtr stavu instalace</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_IncludeInstalledGames">Zahrnout nainstalované hry</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_IncludeInstalledGames_Help">Pokud je povoleno, budou pro export zvažovány pouze nainstalované hry.</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_IncludedPlatforms">Filtry platforem</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_IncludedPlatforms_Help">Vyberte platformy k zahrnutí do exportu. Pokud nejsou vybrány žádné, budou zahrnuty všechny platformy.</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_RequiredLabel">Filtr štítků</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_RequiredLabel_Help">Exportovat pouze hry s tímto štítkem. Ponechte prázdné pro export všech her.</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_NoLabel">Štítek není vyžadován</sys:String>
    <sys:String x:Key="LOC_ApolloSync_DefaultLabel_Name">Apollo/Sunshine</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_CreateDefaultLabel">Vytvořit výchozí štítek</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_CompletionStatusFilter">Filtr stavu dokončení</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_CompletionStatusFilter_Help">Vyberte stavy dokončení k zahrnutí do exportu. Pokud nejsou vybrány žádné, budou zahrnuty všechny stavy dokončení.</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_CategoryFilter">Filtr kategorií</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_CategoryFilter_Help">Vyberte kategorie k zahrnutí do exportu. Pokud nejsou vybrány žádné, budou zahrnuty všechny kategorie.</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_FilterPreset">Předvolba filtru</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_UseFilterPreset">Použít předvolbu filtru Playnite</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_FilterPreset_Help">Pokud je povoleno, bude místo jednotlivých filtrů níže použita vybraná předvolba filtru. Předvolby filtrů vytvořte v hlavním zobrazení knihovny Playnite.</sys:String>

    <!-- Manage Games Tab -->
    <sys:String x:Key="LOC_ApolloSync_Settings_ManageGames">Spravovat exportované hry</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_ManageGames_Help">Zobrazit a spravovat hry exportované do Apollo/Sunshine. Připnuté hry nebudou automaticky odebrány při změně filtrů nebo odinstalování her.</sys:String>

    <!-- Progress and feedback messages -->
    <sys:String x:Key="LOC_ApolloSync_Progress_SyncAll_Title">Synchronizace her do Apollo/Sunshine</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Progress_SyncAll_Current">Zpracování: {0}</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Message_NoInstalledGames">Nebyly nalezeny žádné nainstalované hry k synchronizaci.</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Message_SyncAll_Complete">Synchronizace úspěšně dokončena.

Úspěšné: {0}
Neúspěšné: {1}</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Message_Export_Complete">Export dokončen.

Úspěšné: {0}
Neúspěšné: {1}</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Message_Remove_Complete">Odebrání dokončeno.

Úspěšné: {0}
Neúspěšné: {1}</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Message_Errors">Došlo k chybám</sys:String>
    <!-- New: Permission prompt for apps.json write -->
    <sys:String x:Key="LOC_ApolloSync_Permissions_Prompt_Title">ApolloSync</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Permissions_Prompt_Body">ApolloSync potřebuje oprávnění k zápisu apps.json do Program Files. Povolit opravu oprávnění?</sys:String>
</ResourceDictionary>
