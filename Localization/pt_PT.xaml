<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <sys:String x:Key="LOC_ApolloSync_Settings_AutoExportInstalledGames">Exportar automaticamente jogos instalados para apps.json</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_AutoRemoveUninstalledGames">Remover automaticamente jogos desinstalados do apps.json</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_Enable">Ativar</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_SyncAllOnLibraryUpdate">Ao atualizar a biblioteca, assegurar que todos os jogos instalados estão exportados</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_AppsJsonPath">Caminho para o apps.json do Apollo/Sunshine</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Browse">Procurar</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Browse_Title">Selecionar apps.json</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_AppsJsonPath_Help">Defina o caminho para o ficheiro apps.json do Apollo ou Sunshine. Apenas as entradas geridas por esta extensão serão adicionadas ou removidas.</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_AppsJsonPath_Invalid">O caminho do apps.json é inválido ou inacessível.</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Menu_Export">Exportar para Apollo/Sunshine</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Menu_Remove">Remover do Apollo/Sunshine</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Menu_Pin">Fixar jogo (impedir remoção automática)</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Menu_Unpin">Desfixar jogo (permitir remoção automática)</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Menu_SyncAll">Sincronizar todos os jogos instalados com Apollo/Sunshine</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Menu_ManageGames">Gerir jogos exportados...</sys:String>
    <sys:String x:Key="LOC_ApolloSync_MenuSection">ApolloSync</sys:String>

    <!-- Tabs -->
    <sys:String x:Key="LOC_ApolloSync_Settings_Tab_General">Geral</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_Tab_Filters">Filtros</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_Tab_ManageGames">Gerir jogos</sys:String>

    <!-- General Settings -->
    <sys:String x:Key="LOC_ApolloSync_Settings_SyncOnSettingsUpdated">Sincronizar ao atualizar as definições</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_SyncOnLibraryUpdate">Sincronizar ao atualizar a biblioteca</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_SyncOnStartup">Sincronizar ao iniciar o Playnite</sys:String>

    <!-- Notification Settings -->
    <sys:String x:Key="LOC_ApolloSync_Settings_NotificationMode">Modo de notificação</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_NotificationMode_Always">Mostrar sempre as notificações</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_NotificationMode_OnUpdateOnly">Apenas em operações de sincronização/atualização</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_NotificationMode_Never">Nunca (executar silenciosamente)</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_NotificationMode_Help">Controla quando o ApolloSync apresenta notificações:
• Sempre: Mostrar todas as notificações (exportações, fixações, erros)
• Apenas ao atualizar: Mostrar notificações apenas durante operações de sincronização/atualização
• Nunca: Executar completamente em silêncio</sys:String>

    <!-- Filter Settings -->
    <sys:String x:Key="LOC_ApolloSync_Settings_InstallationStatus">Filtro de estado de instalação</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_IncludeInstalledGames">Incluir jogos instalados</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_IncludeInstalledGames_Help">Quando ativado, apenas os jogos instalados serão considerados para exportação.</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_IncludedPlatforms">Filtros de plataforma</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_IncludedPlatforms_Help">Selecione as plataformas a incluir na exportação. Se nenhuma for selecionada, todas as plataformas serão incluídas.</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_RequiredLabel">Filtro de etiqueta</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_RequiredLabel_Help">Exportar apenas jogos com esta etiqueta. Deixe sem seleção para exportar todos os jogos.</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_NoLabel">Nenhuma etiqueta necessária</sys:String>
    <sys:String x:Key="LOC_ApolloSync_DefaultLabel_Name">Apollo/Sunshine</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_CreateDefaultLabel">Criar etiqueta predefinida</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_CompletionStatusFilter">Filtro de estado de conclusão</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_CompletionStatusFilter_Help">Selecione os estados de conclusão a incluir na exportação. Se nenhum for selecionado, todos os estados serão incluídos.</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_CategoryFilter">Filtro de categoria</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_CategoryFilter_Help">Selecione as categorias a incluir na exportação. Se nenhuma for selecionada, todas as categorias serão incluídas.</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_FilterPreset">Predefinição de filtro</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_UseFilterPreset">Usar predefinição de filtro do Playnite</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_FilterPreset_Help">Quando ativado, a predefinição de filtro selecionada será utilizada em vez dos filtros individuais abaixo. Crie predefinições de filtro na vista principal da biblioteca do Playnite.</sys:String>

    <!-- Manage Games Tab -->
    <sys:String x:Key="LOC_ApolloSync_Settings_ManageGames">Gerir jogos exportados</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_ManageGames_Help">Visualize e faça a gestão dos jogos que foram exportados para o Apollo/Sunshine. Os jogos fixados não serão automaticamente removidos quando os filtros mudarem ou os jogos forem desinstalados.</sys:String>

    <!-- Progress and feedback messages -->
    <sys:String x:Key="LOC_ApolloSync_Progress_SyncAll_Title">A sincronizar jogos com Apollo/Sunshine</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Progress_SyncAll_Current">A processar: {0}</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Message_NoInstalledGames">Nenhum jogo instalado encontrado para sincronizar.</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Message_SyncAll_Complete">Sincronização concluída com sucesso.

Sucesso: {0}
Falhados: {1}</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Message_Export_Complete">Exportação concluída.

Sucesso: {0}
Falhados: {1}</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Message_Remove_Complete">Remoção concluída.

Sucesso: {0}
Falhados: {1}</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Message_Errors">Erros encontrados</sys:String>
    <!-- New: Permission prompt for apps.json write -->
    <sys:String x:Key="LOC_ApolloSync_Permissions_Prompt_Title">ApolloSync</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Permissions_Prompt_Body">O ApolloSync necessita de permissão para escrever o apps.json em Program Files. Permitir a correção das permissões?</sys:String>
</ResourceDictionary>
