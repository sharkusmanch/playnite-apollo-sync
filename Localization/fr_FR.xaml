<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <sys:String x:Key="LOC_ApolloSync_Settings_AutoExportInstalledGames">Exporter automatiquement les jeux installés vers apps.json</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_AutoRemoveUninstalledGames">Supprimer automatiquement les jeux désinstallés de apps.json</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_Enable">Activer</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_SyncAllOnLibraryUpdate">Lors de la mise à jour de la bibliothèque, s'assurer que tous les jeux installés sont exportés</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_AppsJsonPath">Chemin vers le fichier apps.json d'Apollo/Sunshine</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Browse">Parcourir</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Browse_Title">Sélectionner apps.json</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_AppsJsonPath_Help">Définissez le chemin vers le fichier apps.json d'Apollo ou Sunshine. Seules les entrées gérées par cette extension seront ajoutées ou supprimées.</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_AppsJsonPath_Invalid">Le chemin vers apps.json est invalide ou inaccessible.</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Menu_Export">Exporter vers Apollo/Sunshine</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Menu_Remove">Supprimer d'Apollo/Sunshine</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Menu_Pin">Épingler le jeu (empêcher la suppression automatique)</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Menu_Unpin">Désépingler le jeu (autoriser la suppression automatique)</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Menu_SyncAll">Synchroniser tous les jeux installés avec Apollo/Sunshine</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Menu_ManageGames">Gérer les jeux exportés...</sys:String>
    <sys:String x:Key="LOC_ApolloSync_MenuSection">ApolloSync</sys:String>

    <!-- Tabs -->
    <sys:String x:Key="LOC_ApolloSync_Settings_Tab_General">Général</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_Tab_Filters">Filtres</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_Tab_ManageGames">Gérer les jeux</sys:String>

    <!-- General Settings -->
    <sys:String x:Key="LOC_ApolloSync_Settings_SyncOnSettingsUpdated">Synchroniser lors de la mise à jour des paramètres</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_SyncOnLibraryUpdate">Synchroniser lors de la mise à jour de la bibliothèque</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_SyncOnStartup">Synchroniser au démarrage de Playnite</sys:String>

    <!-- Notification Settings -->
    <sys:String x:Key="LOC_ApolloSync_Settings_NotificationMode">Mode de notification</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_NotificationMode_Always">Toujours afficher les notifications</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_NotificationMode_OnUpdateOnly">Uniquement lors des opérations de synchronisation/mise à jour</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_NotificationMode_Never">Jamais (exécuter silencieusement)</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_NotificationMode_Help">Contrôle quand ApolloSync affiche les notifications :
• Toujours : Afficher toutes les notifications (exportations, épinglages, erreurs)
• Mise à jour uniquement : Afficher les notifications uniquement lors des opérations de synchronisation/mise à jour
• Jamais : Exécuter complètement en silence</sys:String>

    <!-- Filter Settings -->
    <sys:String x:Key="LOC_ApolloSync_Settings_InstallationStatus">Filtre d'état d'installation</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_IncludeInstalledGames">Inclure les jeux installés</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_IncludeInstalledGames_Help">Lorsque activé, seuls les jeux installés seront pris en compte pour l'exportation.</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_IncludedPlatforms">Filtres de plateforme</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_IncludedPlatforms_Help">Sélectionnez les plateformes à inclure dans l'exportation. Si aucune n'est sélectionnée, toutes les plateformes seront incluses.</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_RequiredLabel">Filtre d'étiquette</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_RequiredLabel_Help">Exporter uniquement les jeux ayant cette étiquette. Laissez non sélectionné pour exporter tous les jeux.</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_NoLabel">Aucune étiquette requise</sys:String>
    <sys:String x:Key="LOC_ApolloSync_DefaultLabel_Name">Apollo/Sunshine</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_CreateDefaultLabel">Créer l'étiquette par défaut</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_CompletionStatusFilter">Filtre d'état de complétion</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_CompletionStatusFilter_Help">Sélectionnez les états de complétion à inclure dans l'exportation. Si aucun n'est sélectionné, tous les états seront inclus.</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_CategoryFilter">Filtre de catégorie</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_CategoryFilter_Help">Sélectionnez les catégories à inclure dans l'exportation. Si aucune n'est sélectionnée, toutes les catégories seront incluses.</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_FilterPreset">Préréglage de filtre</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_UseFilterPreset">Utiliser un préréglage de filtre Playnite</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_FilterPreset_Help">Lorsque activé, le préréglage de filtre sélectionné sera utilisé à la place des filtres individuels ci-dessous. Créez des préréglages de filtre dans la vue principale de la bibliothèque Playnite.</sys:String>

    <!-- Manage Games Tab -->
    <sys:String x:Key="LOC_ApolloSync_Settings_ManageGames">Gérer les jeux exportés</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_ManageGames_Help">Afficher et gérer les jeux qui ont été exportés vers Apollo/Sunshine. Les jeux épinglés ne seront pas automatiquement supprimés lorsque les filtres changent ou que les jeux sont désinstallés.</sys:String>

    <!-- Progress and feedback messages -->
    <sys:String x:Key="LOC_ApolloSync_Progress_SyncAll_Title">Synchronisation des jeux vers Apollo/Sunshine</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Progress_SyncAll_Current">Traitement : {0}</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Message_NoInstalledGames">Aucun jeu installé trouvé à synchroniser.</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Message_SyncAll_Complete">Synchronisation terminée avec succès.

Réussis : {0}
Échoués : {1}</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Message_Export_Complete">Exportation terminée.

Réussis : {0}
Échoués : {1}</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Message_Remove_Complete">Suppression terminée.

Réussis : {0}
Échoués : {1}</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Message_Errors">Des erreurs ont été rencontrées</sys:String>
    <!-- New: Permission prompt for apps.json write -->
    <sys:String x:Key="LOC_ApolloSync_Permissions_Prompt_Title">ApolloSync</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Permissions_Prompt_Body">ApolloSync a besoin de l'autorisation d'écrire apps.json dans Program Files. Autoriser la correction des permissions ?</sys:String>
</ResourceDictionary>
