<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <sys:String x:Key="LOC_ApolloSync_Settings_AutoExportInstalledGames">Автоматично експортувати встановлені ігри до apps.json</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_AutoRemoveUninstalledGames">Автоматично видаляти деінстальовані ігри з apps.json</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_Enable">Увімкнути</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_SyncAllOnLibraryUpdate">При оновленні бібліотеки переконатися, що всі встановлені ігри експортовано</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_AppsJsonPath">Шлях до файлу Apollo/Sunshine apps.json</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Browse">Огляд</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Browse_Title">Виберіть apps.json</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_AppsJsonPath_Help">Вкажіть шлях до файлу apps.json програми Apollo або Sunshine. Будуть додані/видалені лише записи, керовані цим розширенням.</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_AppsJsonPath_Invalid">Шлях до apps.json недійсний або недоступний.</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Menu_Export">Експортувати до Apollo/Sunshine</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Menu_Remove">Видалити з Apollo/Sunshine</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Menu_Pin">Закріпити гру (запобігти автоматичному видаленню)</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Menu_Unpin">Відкріпити гру (дозволити автоматичне видалення)</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Menu_SyncAll">Синхронізувати всі встановлені ігри з Apollo/Sunshine</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Menu_ManageGames">Керування експортованими іграми...</sys:String>
    <sys:String x:Key="LOC_ApolloSync_MenuSection">ApolloSync</sys:String>

    <!-- Tabs -->
    <sys:String x:Key="LOC_ApolloSync_Settings_Tab_General">Загальні</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_Tab_Filters">Фільтри</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_Tab_ManageGames">Керування іграми</sys:String>

    <!-- General Settings -->
    <sys:String x:Key="LOC_ApolloSync_Settings_SyncOnSettingsUpdated">Синхронізувати при зміні налаштувань</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_SyncOnLibraryUpdate">Синхронізувати при оновленні бібліотеки</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_SyncOnStartup">Синхронізувати при запуску Playnite</sys:String>

    <!-- Notification Settings -->
    <sys:String x:Key="LOC_ApolloSync_Settings_NotificationMode">Режим сповіщень</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_NotificationMode_Always">Завжди показувати сповіщення</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_NotificationMode_OnUpdateOnly">Лише при синхронізації/оновленні</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_NotificationMode_Never">Ніколи (працювати без сповіщень)</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_NotificationMode_Help">Визначає, коли ApolloSync відображає сповіщення:
• Завжди: Показувати всі сповіщення (експорт, закріплення, помилки)
• Лише при оновленні: Показувати сповіщення тільки під час синхронізації/оновлення
• Ніколи: Працювати повністю без сповіщень</sys:String>

    <!-- Filter Settings -->
    <sys:String x:Key="LOC_ApolloSync_Settings_InstallationStatus">Фільтр за статусом встановлення</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_IncludeInstalledGames">Включати встановлені ігри</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_IncludeInstalledGames_Help">Якщо увімкнено, лише встановлені ігри будуть розглядатися для експорту.</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_IncludedPlatforms">Фільтри платформ</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_IncludedPlatforms_Help">Виберіть платформи для включення в експорт. Якщо жодна не вибрана, будуть включені всі платформи.</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_RequiredLabel">Фільтр за мітками</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_RequiredLabel_Help">Експортувати лише ігри з цією міткою. Залиште порожнім, щоб експортувати всі ігри.</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_NoLabel">Мітка не потрібна</sys:String>
    <sys:String x:Key="LOC_ApolloSync_DefaultLabel_Name">Apollo/Sunshine</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_CreateDefaultLabel">Створити мітку за замовчуванням</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_CompletionStatusFilter">Фільтр за статусом проходження</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_CompletionStatusFilter_Help">Виберіть статуси проходження для включення в експорт. Якщо жоден не вибраний, будуть включені всі статуси проходження.</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_CategoryFilter">Фільтр за категоріями</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_CategoryFilter_Help">Виберіть категорії для включення в експорт. Якщо жодна не вибрана, будуть включені всі категорії.</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_FilterPreset">Набір фільтрів</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_UseFilterPreset">Використовувати набір фільтрів Playnite</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_FilterPreset_Help">Якщо увімкнено, замість окремих фільтрів нижче буде використовуватися вибраний набір фільтрів. Створюйте набори фільтрів у головному вигляді бібліотеки Playnite.</sys:String>

    <!-- Manage Games Tab -->
    <sys:String x:Key="LOC_ApolloSync_Settings_ManageGames">Керування експортованими іграми</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Settings_ManageGames_Help">Перегляд і керування іграми, експортованими до Apollo/Sunshine. Закріплені ігри не будуть автоматично видалені при зміні фільтрів або деінсталяції ігор.</sys:String>

    <!-- Progress and feedback messages -->
    <sys:String x:Key="LOC_ApolloSync_Progress_SyncAll_Title">Синхронізація ігор з Apollo/Sunshine</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Progress_SyncAll_Current">Обробка: {0}</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Message_NoInstalledGames">Встановлених ігор для синхронізації не знайдено.</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Message_SyncAll_Complete">Синхронізацію успішно завершено.

Успішно: {0}
Помилок: {1}</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Message_Export_Complete">Експорт завершено.

Успішно: {0}
Помилок: {1}</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Message_Remove_Complete">Видалення завершено.

Успішно: {0}
Помилок: {1}</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Message_Errors">Виявлено помилки</sys:String>
    <!-- New: Permission prompt for apps.json write -->
    <sys:String x:Key="LOC_ApolloSync_Permissions_Prompt_Title">ApolloSync</sys:String>
    <sys:String x:Key="LOC_ApolloSync_Permissions_Prompt_Body">ApolloSync потребує дозволу на запис apps.json у Program Files. Дозволити виправлення прав доступу?</sys:String>
</ResourceDictionary>
